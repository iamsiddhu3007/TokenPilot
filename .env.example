# === MANDATORY (the FOUR platforms) ===
# RocketRide: connects to the local engine started by the VS Code extension
# (connectionMode: local). The estimator pipeline (pipeline/estimate.pipe) routes
# its LLM node through the Butterbase gateway. NOTE: the local engine port is
# ephemeral — if the extension restarts the engine, update ROCKETRIDE_URI (find it
# with: lsof -nP -iTCP -sTCP:LISTEN | grep engine). Falls back to heuristics if down.
ROCKETRIDE_API_KEY=
ROCKETRIDE_URI=localhost:60311       # <host:port> of the local RocketRide engine
ROCKETRIDE_APIKEY=local              # OSS engine accepts any non-empty key (SDK reads this var)
ROCKETRIDE_GATEWAY_URL=https://api.butterbase.ai/v1/<app_id>   # OpenAI-compatible base for the LLM node
ROCKETRIDE_GATEWAY_KEY=              # bb_sk_... (same Butterbase key)

BUTTERBASE_API_KEY=
BUTTERBASE_PROJECT_URL=
BUTTERBASE_GATEWAY_KEY=

XTRACE_API_KEY=
XTRACE_ENDPOINT=https://api.production.xtrace.ai
XTRACE_ORG_ID=          # app.xtrace.ai → Settings (needed by @xtraceai/memory SDK)

# Photon / Spectrum (sign up at app.photon.codes → project id + secret)
PHOTON_PROJECT_ID=
PHOTON_SECRET=
PHOTON_TARGET=          # iMessage recipient: phone "+15551234567" or handle "name@example.com" (proactive pushes only)

# === DATA ===
DATASET_PATH=data/seed_tickets.json

# === OPTIONAL (direct LLM fallback — insurance only) ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# === SERVER ===
PORT=3001
